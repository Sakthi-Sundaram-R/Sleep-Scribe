# --- Backend API (Day 2) ---
# URL of the Sleep-Scribe API server. Defaults to the local dev server.
# For deployment, set this to your deployed API, e.g. https://your-api.onrender.com/api
VITE_API_URL=http://localhost:4000/api

# --- Google sign-in (Day 2) ---
# OAuth 2.0 Client ID (Web) from https://console.cloud.google.com/apis/credentials
# Public value (safe in the browser). Leave blank to hide the Google button.
# Must match GOOGLE_CLIENT_ID in server/.env. Add http://localhost:5173 as an
# "Authorized JavaScript origin" in the Google console.
VITE_GOOGLE_CLIENT_ID=

# Copy this file to `.env` and fill in your key when you wire in real AI (Day 3).
# Vite only exposes variables prefixed with VITE_ to the browser.
# NOTE: For production, proxy AI calls through a backend so your key is never
# shipped to the client. This var is for local prototyping only.

VITE_ANTHROPIC_API_KEY=your_key_here
VITE_AI_MODEL=claude-opus-4-8
