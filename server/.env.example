# Sleep-Scribe API — environment
# Copy to ".env" and fill in. Never commit the real .env.

# MongoDB connection string.
# - Leave BLANK for local dev: the server boots an in-memory MongoDB automatically.
# - For "real" / deployed: paste your MongoDB Atlas connection string here, e.g.
#   mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/sleepscribe?retryWrites=true&w=majority
MONGODB_URI=

# Secret used to sign login tokens (use a long random string in production).
JWT_SECRET=dev-secret-change-me

# Port the API listens on.
PORT=4000

# Comma-separated list of allowed frontend origins (CORS).
CLIENT_ORIGIN=http://localhost:5173

# --- Google sign-in (Day 2) ---
# Same OAuth 2.0 Client ID as VITE_GOOGLE_CLIENT_ID (the backend verifies
# Google tokens against it). Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=

# --- Day 3: Groq LLM ---
# Get a free key at https://console.groq.com (it starts with "gsk_").
# Leave blank to fall back to the offline heuristic analyzer.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Email ---
# Powers password-reset and the weekly digest. Two options:
#
# Option A (default) — Gmail SMTP: sends FROM a real Gmail address. Enable
# 2-Step Verification on the account, then Google Account -> Security ->
# App passwords -> generate one and paste it below (spaces are fine).
GMAIL_USER=
GMAIL_APP_PASSWORD=
#
# Option B — Resend (HTTP API). Requires a verified domain; a @gmail.com From
# is NOT allowed. Get a key at https://resend.com (starts with "re_").
RESEND_API_KEY=
#
# Sender address (display name + email). For Gmail this must be the GMAIL_USER
# address; for Resend it must be on your verified domain.
EMAIL_FROM=SleepScribe <sleepscribeonline@gmail.com>

# --- Weekly digest cron (Vercel Cron) ---
# A long random string. Vercel sends it as a Bearer token to the cron endpoint
# so /api/cron/weekly-digest can't be triggered publicly. Leave blank to disable.
CRON_SECRET=
